# VAPI Platform
VAPI_API_KEY=                          # From dashboard.vapi.ai
VAPI_WEBHOOK_URL=                      # https://fmofl-command.vercel.app/api/vapi/webhook
VAPI_OUTBOUND_PHONE_NUMBER_ID=        # Phone number ID (if needed later for outbound)

# Application
VERCEL_URL=fmofl-command.vercel.app

# Practice
PRACTICE_TRANSFER_NUMBER=+14078023233  # Office line for human transfer

# Google Sheets (for logging all agent actions)
GOOGLE_SHEET_ID=                       # Spreadsheet ID from the URL
GOOGLE_SERVICE_ACCOUNT_EMAIL=          # Service account email (e.g., fmofl-bot@project.iam.gserviceaccount.com)
GOOGLE_PRIVATE_KEY=                    # RSA private key from service account JSON (paste the full -----BEGIN...END----- block)

# ────────────────────────────────────────────────────────────
# TAVUS V·FACE (Video Concierge)
# ────────────────────────────────────────────────────────────
TAVUS_API_KEY=                         # From tavus.io dashboard
TAVUS_PERSONA_ID=                      # Created via POST /api/vface/setup
TAVUS_REPLICA_ID=                      # Selected from Tavus replica gallery
VFACE_BASE_URL=                        # Override callback URL base (optional, defaults to VERCEL_URL)
